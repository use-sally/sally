generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskPriority {
  P1
  P2
  P3
}

enum TaskStatusType {
  BACKLOG
  TODO
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
}

enum PlatformRole {
  NONE
  ADMIN
  SUPERADMIN
}

enum WorkspaceRole {
  OWNER
  MEMBER
  VIEWER
}

enum ProjectRole {
  OWNER
  MEMBER
  VIEWER
}

enum TaskParticipantRole {
  OWNER
  PARTICIPANT
}

enum PrincipalType {
  HUMAN
  AGENT
}

enum WorkflowStage {
  INTAKE
  PLANNING
  ARCHITECTURE
  EXECUTION
  REVIEW
  TESTING
  REWORK
  APPROVAL_NEEDED
  BLOCKED
  DEPLOYMENT
  DONE
}

enum AgentJobStatus {
  QUEUED
  CLAIMED
  RUNNING
  SUCCEEDED
  FAILED
  BLOCKED
  CANCELLED
  TIMED_OUT
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  BLOCKED
  CANCELLED
  TIMED_OUT
}

enum WorkItemProvider {
  SALLY
  LINEAR
  JIRA
  GITHUB
}

enum TaskResourceProvider {
  GOOGLE_DRIVE
  MICROSOFT_365
  DROPBOX
}

enum TaskResourceKind {
  FILE
  FOLDER
  LINK
}

enum AgentConnectionStatus {
  ONLINE
  OFFLINE
  DEGRADED
  REVOKED
}

enum ApprovalType {
  LIVE_DEPLOY
  CREDENTIAL
  PAYMENT_DATA
  CUSTOMER_DATA
  CLIENT_DECISION
  DESTRUCTIVE_ACTION
  PUBLISHING
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BlockerType {
  CREDENTIAL
  ACCESS
  STAGING_FAILURE
  ARCHITECTURE_CONFLICT
  TEST_FAILURE
  CLIENT_DECISION
  LIVE_APPROVAL
  DEPENDENCY
  AMBIGUITY
  TOOLING_FAILURE
}

enum BlockerStatus {
  OPEN
  RESOLVED
  CANCELLED
}

enum CrmDealStatus {
  OPEN
  WON
  LOST
}

enum CrmActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  FOLLOW_UP
}

enum CrmFollowUpStatus {
  OPEN
  DONE
  CANCELLED
}

model Workspace {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  archivedAt               DateTime?
  projects                 Project[]
  clients                  Client[]
  crmOrganizations         CrmOrganization[]
  crmPeople                CrmPerson[]
  crmDeals                 CrmDeal[]
  crmActivities            CrmActivity[]
  crmFollowUps             CrmFollowUp[]
  users                    User[]
  memberships              WorkspaceMembership[]
  invites                  AccountInvite[]
  activityLogs             ActivityLog[]
  auditLogEvents           AuditLogEvent[]
  notifications            Notification[]
  mcpKeys                  AccountMcpKey[]
  agentIdentities          AgentIdentity[]
  agentConnections         AgentConnection[]
  agentPairingCodes        AgentPairingCode[]
  agentEvents              AgentEvent[]
  agentEventAcks           AgentEventAck[]
  agentJobs                AgentJob[]
  agentRuns                AgentRun[]
  workItemRefs             WorkItemRef[]
  approvalRequests         ApprovalRequest[]
  blockers                 Blocker[]
  projectAutomationConfigs ProjectAutomationConfig[]

  @@index([archivedAt])
}

model Account {
  id                      String                      @id @default(cuid())
  email                   String                      @unique
  name                    String?
  avatarUrl               String?
  passwordHash            String?
  platformRole            PlatformRole                @default(NONE)
  appearanceFontScale     Float                       @default(1.0)
  appearanceTheme         String                      @default("dark")
  appearanceStatusTint    Float                       @default(30.0)
  archivedAt              DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  memberships             WorkspaceMembership[]
  projectMemberships      ProjectMembership[]
  sessions                AccountSession[]
  apiKeys                 AccountApiKey[]
  mcpKeys                 AccountMcpKey[]
  emailChanges            EmailChangeToken[]
  invites                 AccountInvite[]
  passwordResets          PasswordReset[]
  authoredComments        Comment[]
  sentNotifications       Notification[]              @relation("NotificationActor")
  receivedNotifications   Notification[]              @relation("NotificationRecipient")
  notificationPreferences NotificationPreference[]
  commentMentions         CommentMention[]
  agentIdentity           AgentIdentity?
  createdAgentJobs        AgentJob[]                  @relation("AgentJobCreator")
  decidedApprovals        ApprovalRequest[]           @relation("ApprovalDecider")
  auditLogEvents          AuditLogEvent[]             @relation("AuditLogActor")
  twoFactorCredential     AccountTwoFactorCredential?
  twoFactorChallenges     AccountTwoFactorChallenge[]
  webAuthnCredentials     AccountWebAuthnCredential[]
  webAuthnChallenges      AccountWebAuthnChallenge[]
  integrations            AccountIntegration[]
  connectedTaskResources  TaskConnectedResource[]
  ownedCrmOrganizations   CrmOrganization[]           @relation("CrmOrganizationOwner")
  ownedCrmDeals           CrmDeal[]                   @relation("CrmDealOwner")
  crmActivities           CrmActivity[]               @relation("CrmActivityActor")
  crmFollowUps            CrmFollowUp[]               @relation("CrmFollowUpOwner")
  createdCrmFollowUps     CrmFollowUp[]               @relation("CrmFollowUpCreator")

  @@index([archivedAt])
}

model CloudStorageProviderConfig {
  provider        TaskResourceProvider @id
  enabled         Boolean              @default(false)
  clientId        String?
  clientSecretEnc String?
  tenantId        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model AccountIntegration {
  id                String               @id @default(cuid())
  accountId         String
  provider          TaskResourceProvider
  accessTokenEnc    String
  refreshTokenEnc   String?
  expiresAt         DateTime?
  scopes            String?
  externalAccountId String?
  externalEmail     String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  account           Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, provider])
  @@index([provider])
}

model AccountTwoFactorCredential {
  id          String    @id @default(cuid())
  accountId   String    @unique
  secret      String
  enabled     Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model AccountTwoFactorChallenge {
  id        String    @id @default(cuid())
  accountId String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model AccountWebAuthnCredential {
  id           String    @id @default(cuid())
  accountId    String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String?
  backedUp     Boolean   @default(false)
  transports   String[]  @default([])
  label        String?
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  account      Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model AccountWebAuthnChallenge {
  id        String    @id @default(cuid())
  accountId String
  token     String    @unique
  type      String
  challenge String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model AccountInvite {
  id          String        @id @default(cuid())
  email       String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  token       String        @unique
  createdAt   DateTime      @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?
  accountId   String?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account     Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([workspaceId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  accountId String
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model EmailChangeToken {
  id        String    @id @default(cuid())
  accountId String
  newEmail  String
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([newEmail])
  @@index([expiresAt])
}

model ActivityLog {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String?
  taskId      String?
  actorName   String?
  actorEmail  String?
  type        String
  summary     String
  payload     Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
}

model InstalledLicense {
  id               String    @id @default("instance")
  licenseServerUrl String
  certificate      String
  publicKey        String
  activationId     String?
  licenseId        String?
  instanceId       String?
  status           String?
  validUntil       DateTime?
  graceUntil       DateTime?
  lastRefreshAt    DateTime?
  nextRefreshAt    DateTime?
  lastRefreshError String?
  installedAt      DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SamlIdentityProvider {
  id              String   @id @default("default")
  entityId        String
  ssoUrl          String
  certificate     String
  allowedDomains  String[] @default([])
  jitProvisioning Boolean  @default(false)
  enabled         Boolean  @default(false)
  enforceSso      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AutomationGovernancePolicy {
  id                            String   @id @default("instance")
  allowedRuntimeTypes           String[] @default([])
  workflowStartRoles            String[] @default(["OWNER", "MEMBER"])
  maxConcurrentWorkflowJobs     Int      @default(1)
  workflowStartRequiresApproval Boolean  @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model ApiMcpKeyPolicy {
  id                             String   @id @default("instance")
  requireApiKeyExpiry            Boolean  @default(false)
  requireMcpKeyExpiry            Boolean  @default(false)
  apiKeyDefaultExpiresInDays     Int?
  apiKeyMaxExpiresInDays         Int?
  mcpKeyDefaultExpiresInDays     Int?
  mcpKeyMaxExpiresInDays         Int?
  restrictApiKeyCreationToAdmins Boolean  @default(false)
  restrictMcpKeyCreationToAdmins Boolean  @default(false)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model SessionPolicy {
  id                            String   @id @default("instance")
  maxSessionLifetimeDays        Int      @default(30)
  revokeOnPolicyChange          Boolean  @default(false)
  restrictSessionPolicyToAdmins Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model TwoFactorPolicy {
  id                         String   @id @default("instance")
  enforcementTarget          String   @default("NONE")
  gracePeriodDays            Int      @default(14)
  allowRecoveryResetByAdmins Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model AuditLogPolicy {
  id                      String   @id @default("instance")
  retentionDays           Int      @default(365)
  exportRequiresAdmin     Boolean  @default(true)
  includeAuthEvents       Boolean  @default(true)
  includeAutomationEvents Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model AuthenticationPolicy {
  id                         String   @id @default("instance")
  minimumPasswordLength      Int      @default(12)
  requirePasswordUppercase   Boolean  @default(true)
  requirePasswordLowercase   Boolean  @default(true)
  requirePasswordNumber      Boolean  @default(true)
  requirePasswordSymbol      Boolean  @default(true)
  disablePasswordLoginForSso Boolean  @default(false)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model SamlAuthRequest {
  id         String    @id
  relayState String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
}

model AuditLogEvent {
  id             String         @id @default(cuid())
  workspaceId    String?
  actorAccountId String?
  projectId      String?
  taskId         String?
  agentId        String?
  agentJobId     String?
  agentRunId     String?
  action         String
  targetType     String?
  targetId       String?
  summary        String?
  metadata       Json?
  createdAt      DateTime       @default(now())
  workspace      Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor          Account?       @relation("AuditLogActor", fields: [actorAccountId], references: [id], onDelete: SetNull)
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task           Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agent          AgentIdentity? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentJob       AgentJob?      @relation(fields: [agentJobId], references: [id], onDelete: SetNull)
  agentRun       AgentRun?      @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorAccountId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
}

model Notification {
  id                 String                 @id @default(cuid())
  workspaceId        String
  projectId          String?
  taskId             String?
  actorAccountId     String?
  recipientAccountId String
  type               String
  title              String
  body               String
  data               Json?
  readAt             DateTime?
  createdAt          DateTime               @default(now())
  workspace          Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project            Project?               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task               Task?                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor              Account?               @relation("NotificationActor", fields: [actorAccountId], references: [id], onDelete: SetNull)
  recipient          Account                @relation("NotificationRecipient", fields: [recipientAccountId], references: [id], onDelete: Cascade)
  deliveries         NotificationDelivery[]

  @@index([recipientAccountId, readAt, createdAt])
  @@index([workspaceId, createdAt])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  accountId    String
  eventType    String
  inAppEnabled Boolean  @default(true)
  emailEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, eventType])
}

model NotificationDelivery {
  id             String       @id @default(cuid())
  notificationId String
  channel        String
  status         String       @default("pending")
  attempts       Int          @default(0)
  lastError      String?
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([channel, status, createdAt])
}

model CommentMention {
  id                 String   @id @default(cuid())
  commentId          String
  mentionedAccountId String
  createdAt          DateTime @default(now())
  comment            Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedAccount   Account  @relation(fields: [mentionedAccountId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedAccountId])
  @@index([mentionedAccountId, createdAt])
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  workspaceId String
  accountId   String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account     Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, accountId])
  @@index([accountId])
}

model ProjectMembership {
  id        String      @id @default(cuid())
  projectId String
  accountId String
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([projectId, accountId])
  @@index([accountId])
}

model AccountSession {
  id        String    @id @default(cuid())
  accountId String
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model AccountApiKey {
  id         String    @id @default(cuid())
  accountId  String
  label      String
  prefix     String
  tokenHash  String    @unique
  scopes     String[]  @default(["read", "write"])
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AccountMcpKey {
  id          String     @id @default(cuid())
  accountId   String
  workspaceId String?
  label       String
  prefix      String
  tokenHash   String     @unique
  scopes      String[]   @default(["read", "write", "mcp"])
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  account     Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([workspaceId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Client {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects    Project[]

  @@unique([workspaceId, name])
}

model CrmOrganization {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  website     String?
  email       String?
  phone       String?
  industry    String?
  size        String?
  source      String?
  address     String?
  city        String?
  region      String?
  postalCode  String?
  country     String?
  notes       String?
  labels      Json?
  ownerId     String?
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner       Account?      @relation("CrmOrganizationOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  people      CrmPerson[]
  deals       CrmDeal[]
  activities  CrmActivity[]
  followUps   CrmFollowUp[]

  @@index([workspaceId, archivedAt])
  @@index([workspaceId, name])
  @@index([ownerId])
}

model CrmPerson {
  id             String           @id @default(cuid())
  workspaceId    String
  organizationId String?
  name           String
  email          String?
  phone          String?
  mobile         String?
  title          String?
  linkedinUrl    String?
  source         String?
  notes          String?
  labels         Json?
  archivedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization   CrmOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  deals          CrmDeal[]        @relation("CrmDealPrimaryPerson")
  activities     CrmActivity[]
  followUps      CrmFollowUp[]

  @@index([workspaceId, archivedAt])
  @@index([workspaceId, name])
  @@index([workspaceId, email])
  @@index([organizationId])
}

model CrmDeal {
  id              String           @id @default(cuid())
  workspaceId     String
  organizationId  String?
  primaryPersonId String?
  ownerId         String?
  projectId       String?
  title           String
  value           Int?
  currency        String?
  stage           String?
  status          CrmDealStatus    @default(OPEN)
  probability     Int?
  nextStep        String?
  expectedCloseAt DateTime?
  notes           String?
  archivedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization    CrmOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  primaryPerson   CrmPerson?       @relation("CrmDealPrimaryPerson", fields: [primaryPersonId], references: [id], onDelete: SetNull)
  owner           Account?         @relation("CrmDealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  activities      CrmActivity[]
  followUps       CrmFollowUp[]

  @@index([workspaceId, archivedAt])
  @@index([workspaceId, status])
  @@index([organizationId])
  @@index([primaryPersonId])
  @@index([ownerId])
  @@index([projectId])
}

model CrmFollowUp {
  id             String            @id @default(cuid())
  workspaceId    String
  organizationId String?
  personId       String?
  dealId         String?
  ownerId        String?
  createdById    String?
  title          String
  body           String?
  status         CrmFollowUpStatus @default(OPEN)
  dueAt          DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization   CrmOrganization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  person         CrmPerson?        @relation(fields: [personId], references: [id], onDelete: SetNull)
  deal           CrmDeal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  owner          Account?          @relation("CrmFollowUpOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy      Account?          @relation("CrmFollowUpCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, dueAt])
  @@index([organizationId])
  @@index([personId])
  @@index([dealId])
  @@index([ownerId])
  @@index([createdById])
}

model CrmActivity {
  id             String           @id @default(cuid())
  workspaceId    String
  organizationId String?
  personId       String?
  dealId         String?
  actorId        String?
  taskId         String?
  type           CrmActivityType  @default(NOTE)
  body           String
  occurredAt     DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization   CrmOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  person         CrmPerson?       @relation(fields: [personId], references: [id], onDelete: SetNull)
  deal           CrmDeal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  actor          Account?         @relation("CrmActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
  @@index([organizationId])
  @@index([personId])
  @@index([dealId])
  @@index([actorId])
  @@index([taskId])
}

model User {
  id          String           @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  timesheets  TimesheetEntry[]

  @@unique([workspaceId, name])
}

model Project {
  id                String                   @id @default(cuid())
  workspaceId       String
  clientId          String?
  name              String
  slug              String
  description       String?
  taskCounter       Int                      @default(0)
  archivedAt        DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  workspace         Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client            Client?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  statuses          TaskStatus[]
  tasks             Task[]
  labels            Label[]
  timesheets        TimesheetEntry[]
  memberships       ProjectMembership[]
  activityLogs      ActivityLog[]
  auditLogEvents    AuditLogEvent[]
  notifications     Notification[]
  dependencies      ProjectDependency[]      @relation("projectDependencies")
  dependedOnBy      ProjectDependency[]      @relation("projectDependedOnBy")
  automationConfig  ProjectAutomationConfig?
  agentConnections  AgentConnection[]
  agentPairingCodes AgentPairingCode[]
  agentJobs         AgentJob[]
  agentRuns         AgentRun[]
  workItemRefs      WorkItemRef[]
  approvalRequests  ApprovalRequest[]
  blockers          Blocker[]
  crmDeals          CrmDeal[]

  @@unique([workspaceId, slug])
}

model ProjectDependency {
  projectId   String
  dependsOnId String
  createdAt   DateTime @default(now())
  project     Project  @relation("projectDependencies", fields: [projectId], references: [id], onDelete: Cascade)
  dependsOn   Project  @relation("projectDependedOnBy", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@id([projectId, dependsOnId])
}

model TaskStatus {
  id        String         @id @default(cuid())
  projectId String
  name      String
  type      TaskStatusType
  position  Int
  color     String?
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([projectId, position])
}

model Task {
  id                 String                  @id @default(cuid())
  projectId          String
  statusId           String
  number             Int
  title              String
  description        String?
  priority           TaskPriority            @default(P2)
  owner              String?
  assignee           String?
  dueDate            DateTime?
  position           Int                     @default(0)
  archivedAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  project            Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status             TaskStatus              @relation(fields: [statusId], references: [id], onDelete: Restrict)
  comments           Comment[]
  labels             TaskLabel[]
  participants       TaskParticipant[]
  collaborators      TaskCollaborator[]
  todos              TaskTodo[]
  timesheets         TimesheetEntry[]
  activityLogs       ActivityLog[]
  auditLogEvents     AuditLogEvent[]
  notifications      Notification[]
  dependencies       TaskDependency[]        @relation("taskDependencies")
  dependedOnBy       TaskDependency[]        @relation("taskDependedOnBy")
  agentJobs          AgentJob[]
  agentRuns          AgentRun[]
  workItemRefs       WorkItemRef[]
  approvalRequests   ApprovalRequest[]
  blockers           Blocker[]
  connectedResources TaskConnectedResource[]

  @@unique([projectId, number])
}

model TaskConnectedResource {
  id                   String               @id @default(cuid())
  taskId               String
  provider             TaskResourceProvider
  kind                 TaskResourceKind     @default(LINK)
  externalId           String
  name                 String
  webUrl               String
  mimeType             String?
  connectedByAccountId String?
  metadata             Json?
  createdAt            DateTime             @default(now())
  task                 Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  connectedBy          Account?             @relation(fields: [connectedByAccountId], references: [id], onDelete: SetNull)

  @@unique([taskId, provider, externalId])
  @@index([taskId])
  @@index([connectedByAccountId])
}

model WorkItemRef {
  id                  String           @id @default(cuid())
  workspaceId         String
  projectId           String?
  provider            WorkItemProvider
  externalId          String?
  externalUrl         String?
  titleSnapshot       String?
  descriptionSnapshot String?
  sallyTaskId         String?
  metadata            Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  workspace           Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project             Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sallyTask           Task?            @relation(fields: [sallyTaskId], references: [id], onDelete: Cascade)
  agentJobs           AgentJob[]
  agentRuns           AgentRun[]

  @@unique([workspaceId, provider, externalId])
  @@unique([workspaceId, provider, sallyTaskId])
  @@index([workspaceId, provider, createdAt])
  @@index([projectId, provider, createdAt])
  @@index([sallyTaskId])
}

model TaskParticipant {
  taskId      String
  participant String
  role        TaskParticipantRole
  position    Int
  createdAt   DateTime            @default(now())
  task        Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, participant])
  @@unique([taskId, position])
}

model TaskCollaborator {
  taskId       String
  collaborator String
  createdAt    DateTime @default(now())
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, collaborator])
}

model TaskDependency {
  taskId      String
  dependsOnId String
  createdAt   DateTime @default(now())
  task        Task     @relation("taskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn   Task     @relation("taskDependedOnBy", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@id([taskId, dependsOnId])
}

model Comment {
  id              String           @id @default(cuid())
  taskId          String
  body            String
  author          String
  authorAccountId String?
  createdAt       DateTime         @default(now())
  task            Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorAccount   Account?         @relation(fields: [authorAccountId], references: [id], onDelete: SetNull)
  mentions        CommentMention[]
}

model Label {
  id        String      @id @default(cuid())
  projectId String
  name      String
  createdAt DateTime    @default(now())
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskLinks TaskLabel[]

  @@unique([projectId, name])
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model TaskTodo {
  id        String   @id @default(cuid())
  taskId    String
  text      String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model AgentIdentity {
  id               String             @id @default(cuid())
  workspaceId      String
  accountId        String?            @unique
  name             String
  role             String
  principalType    PrincipalType      @default(AGENT)
  hermesProfile    String?
  allowedProjects  Json?
  allowedTaskKinds Json?
  capabilities     Json?
  enabled          Boolean            @default(true)
  lastSeenAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account          Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)
  jobs             AgentJob[]
  runs             AgentRun[]
  connections      AgentConnection[]
  pairingCodes     AgentPairingCode[]
  approvalRequests ApprovalRequest[]  @relation("ApprovalRequester")
  blockers         Blocker[]
  auditLogEvents   AuditLogEvent[]

  @@unique([workspaceId, role, name])
  @@index([workspaceId, role])
  @@index([workspaceId, enabled])
}

model AgentConnection {
  id             String                @id @default(cuid())
  workspaceId    String
  projectId      String?
  agentId        String?
  name           String
  runtimeType    String
  runtimeVersion String?
  profileRef     String?
  status         AgentConnectionStatus @default(OFFLINE)
  capabilities   Json?
  tokenPrefix    String
  tokenHash      String                @unique
  lastSeenAt     DateTime?
  revokedAt      DateTime?
  metadata       Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project?              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent          AgentIdentity?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  eventAcks      AgentEventAck[]

  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, projectId, status, updatedAt])
  @@index([workspaceId, agentId])
  @@index([revokedAt])
}

model AgentPairingCode {
  id          String         @id @default(cuid())
  workspaceId String
  projectId   String?
  agentId     String?
  codeHash    String         @unique
  name        String
  runtimeType String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime       @default(now())
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent       AgentIdentity? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, expiresAt])
  @@index([workspaceId, projectId, expiresAt])
  @@index([agentId])
}

model AgentEvent {
  id          String    @id @default(cuid())
  workspaceId String
  agentId     String?
  type        String
  payload     Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, id])
  @@index([workspaceId, type, createdAt])
  @@index([agentId, createdAt])
}

model AgentEventAck {
  id           String          @id @default(cuid())
  workspaceId  String
  connectionId String
  lastEventId  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connection   AgentConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId])
  @@index([workspaceId, updatedAt])
}

model ProjectAutomationConfig {
  id                         String        @id @default(cuid())
  workspaceId                String
  projectId                  String        @unique
  workflowEnabled            Boolean       @default(false)
  defaultPmAgentId           String?
  roleAgents                 Json?
  baselineTaskIds            Json?
  requiredCapabilities       Json?
  liveActionsRequireApproval Boolean       @default(true)
  stagingFirst               Boolean       @default(true)
  currentStage               WorkflowStage @default(INTAKE)
  nextRole                   String?
  automationState            String        @default("idle")
  metadata                   Json?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  workspace                  Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project                    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId, workflowEnabled])
  @@index([currentStage])
}

model AgentJob {
  id             String          @id @default(cuid())
  workspaceId    String
  projectId      String?
  taskId         String?
  agentId        String?
  createdById    String?
  role           String
  mode           String          @default("task")
  status         AgentJobStatus  @default(QUEUED)
  triggerType    String
  workflowRunId  String?
  workflowStep   Int?
  maxSteps       Int?
  workItemRefId  String?
  payload        Json?
  lockedAt       DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  error          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task           Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workItemRef    WorkItemRef?    @relation(fields: [workItemRefId], references: [id], onDelete: SetNull)
  agent          AgentIdentity?  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  createdBy      Account?        @relation("AgentJobCreator", fields: [createdById], references: [id], onDelete: SetNull)
  runs           AgentRun[]
  auditLogEvents AuditLogEvent[]

  @@index([workspaceId, status, createdAt])
  @@index([projectId, status, createdAt])
  @@index([taskId, createdAt])
  @@index([workItemRefId, createdAt])
  @@index([workflowRunId, workflowStep])
}

model AgentRun {
  id                String          @id @default(cuid())
  workspaceId       String
  projectId         String?
  taskId            String?
  jobId             String?
  agentId           String?
  role              String
  status            AgentRunStatus  @default(QUEUED)
  triggerType       String
  provider          String?
  model             String?
  workflowRunId     String?
  workflowStep      Int?
  workItemRefId     String?
  startedAt         DateTime?
  finishedAt        DateTime?
  latestHeartbeatAt DateTime?
  summary           String?
  logUrl            String?
  evidenceUrl       String?
  error             String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project           Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task              Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workItemRef       WorkItemRef?    @relation(fields: [workItemRefId], references: [id], onDelete: SetNull)
  job               AgentJob?       @relation(fields: [jobId], references: [id], onDelete: SetNull)
  agent             AgentIdentity?  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  auditLogEvents    AuditLogEvent[]

  @@index([workspaceId, status, createdAt])
  @@index([projectId, status, createdAt])
  @@index([taskId, createdAt])
  @@index([workItemRefId, createdAt])
  @@index([jobId])
  @@index([workflowRunId, workflowStep])
}

model ApprovalRequest {
  id                 String         @id @default(cuid())
  workspaceId        String
  projectId          String?
  taskId             String?
  requestedByAgentId String?
  decidedByAccountId String?
  type               ApprovalType
  status             ApprovalStatus @default(PENDING)
  question           String
  options            Json?
  recommendation     String?
  decisionNote       String?
  decidedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project            Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task               Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requestedByAgent   AgentIdentity? @relation("ApprovalRequester", fields: [requestedByAgentId], references: [id], onDelete: SetNull)
  decidedByAccount   Account?       @relation("ApprovalDecider", fields: [decidedByAccountId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([projectId, status, createdAt])
  @@index([taskId, status, createdAt])
}

model Blocker {
  id            String         @id @default(cuid())
  workspaceId   String
  projectId     String?
  taskId        String?
  ownerAgentId  String?
  type          BlockerType
  status        BlockerStatus  @default(OPEN)
  summary       String
  requiredInput String?
  resolvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  ownerAgent    AgentIdentity? @relation(fields: [ownerAgentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([projectId, status, createdAt])
  @@index([taskId, status, createdAt])
}

model TimesheetEntry {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  taskId      String?
  date        DateTime
  minutes     Int
  description String?
  billable    Boolean  @default(true)
  validated   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([taskId, date])
  @@index([userId, date])
}
